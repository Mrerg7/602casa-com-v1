---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const {
  title,
  description,
  ogImage = 'https://picsum.photos/id/160/1200/630',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="Rc0Aaa9IaqMIh6MykVUjSbZVovDxK1nblYTH61Mwyns" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="602Casa.com" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <!-- Structured Data: WebSite -->
    <script type="application/ld+json" is:inline set:html={`{
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "602Casa.com",
      "url": "${Astro.site}",
      "description": "${description}"
    }`}>
    </script>

    <!-- Structured Data: Product (Domain Listing) -->
    <script type="application/ld+json" is:inline set:html={`{
      "@context": "https://schema.org",
      "@type": "Product",
      "name": "602Casa.com Premium Domain",
      "description": "Premium .com domain for homes in Phoenix 602 area code. Ideal for real estate platforms, home services, and property branding.",
      "url": "${Astro.site}",
      "category": "Digital Asset / Domain Name",
      "brand": {
        "@type": "Brand",
        "name": "602Casa.com"
      },
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD",
        "availability": "https://schema.org/OnlineOnly",
        "seller": {
          "@type": "Organization",
          "name": "DesertRich LLC",
          "contactPoint": {
            "@type": "ContactPoint",
            "email": "sales@desertrich.com",
            "contactType": "sales",
            "availableLanguage": "English"
          }
        }
      }
    }`}>
    </script>

    <!-- Structured Data: Organization -->
    <script type="application/ld+json" is:inline set:html={`{
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "DesertRich LLC",
      "url": "${Astro.site}",
      "description": "${description}",
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "sales@desertrich.com",
        "contactType": "sales",
        "availableLanguage": "English"
      }
    }`}>
    </script>
  </head>
  <body class="bg-slate-50 text-slate-900 antialiased">
    <slot />
  </body>
</html>
