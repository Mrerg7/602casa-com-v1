    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5 max-w-7xl mx-auto">
      <div class="bg-white border border-slate-200 rounded-3xl p-7 hover:-translate-y-1 hover:shadow-lg transition-all duration-200">
        <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-accent-600 to-accent-700 flex items-center justify-center mb-6">
          <i class="fa-solid fa-home text-white text-xl"></i>
        </div>
        <h3 class="font-semibold text-xl tracking-tight mb-3">Instant Home Authority</h3>
        <p class="text-slate-600 leading-relaxed text-sm">602 is the original, iconic Phoenix area code. &ldquo;Casa&rdquo; instantly communicates homes, real estate, and belonging. Together they create immediate local trust in central Phoenix.</p>
      </div>

      <div class="bg-white border border-slate-200 rounded-3xl p-7 hover:-translate-y-1 hover:shadow-lg transition-all duration-200">
        <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-amber-600 to-accent-700 flex items-center justify-center mb-6">
