---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = '602Casa.com | Premium Real Estate & Home Domain for Phoenix 602 | For Sale';
const description =
  'Own the most memorable domain for homes in central Phoenix. Perfect for building the definitive 602 home platform or branding your real estate, home services, or property business with instant local authority.';
---

<BaseLayout {title} {description}>
  <!-- Navbar -->
  <nav id="navbar" class="bg-white border-b border-slate-200 sticky top-0 z-50 transition-all duration-300">
    <div class="max-w-screen-2xl mx-auto">
      <div class="px-8 py-5 flex items-center justify-between">
        <div class="flex items-center gap-x-3">
          <div class="flex items-center gap-x-2.5">
            <div class="w-11 h-11 bg-slate-900 rounded-2xl flex items-center justify-center shadow-inner">
              <span class="text-white font-display text-2xl font-semibold tracking-tighter">602</span>
            </div>
            <div>
              <span class="font-display text-2xl font-semibold tracking-tighter">Casa</span>
              <span class="text-xs font-mono text-slate-400 tracking-[3px] block -mt-1">.COM</span>
            </div>
          </div>
        </div>

        <div class="hidden md:flex items-center gap-x-9 text-sm font-medium">
          <a href="#why" class="text-slate-600 hover:text-slate-900 transition-colors">Why This Domain</a>
