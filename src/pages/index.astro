          <div class="mt-auto">
            <div class="text-xs font-bold tracking-widest text-slate-500 mb-3">IDEAL FOR</div>
            <div class="flex flex-wrap gap-2">
              <span class="px-4 py-1.5 text-xs font-medium bg-white border border-slate-200 rounded-2xl">Real Estate Hub &amp; Guides</span>
