              </div>
            </div>
          </div>
        </div>
        <div class="md:col-span-7 mt-10 md:mt-0">
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div class="bg-[#F8FAFC] border border-[#E2E8F0] rounded-3xl p-6">
              <div class="text-accent-600 text-xs font-bold tracking-widest">REAL ESTATE ACTIVITY</div>
