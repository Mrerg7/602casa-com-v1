            onclick="document.getElementById('why').scrollIntoView({ behavior: 'smooth' })"
            class="inline-flex items-center justify-center gap-x-2 px-7 py-4 text-base font-medium border border-white/30 hover:bg-white/10 text-white rounded-3xl transition-all"
