          <div class="flex items-center gap-x-4 mb-6">
            <div class="w-[52px] h-[52px] rounded-full bg-gradient-to-br from-accent-200 to-accent-600 flex items-center justify-center flex-shrink-0">
              <i class="fa-solid fa-globe text-slate-900 text-xl"></i>
            </div>
            <div>
              <span class="px-3 py-1 text-xs font-bold tracking-widest bg-white border border-slate-200 rounded-2xl">PATH 1</span>
            </div>
          </div>
