          <a href="#value" class="text-slate-600 hover:text-slate-900 transition-colors">Market Value</a>
          <a href="#acquire" class="text-slate-600 hover:text-slate-900 transition-colors">How to Acquire</a>
        </div>

        <div class="flex items-center gap-x-3">
          <button
            onclick="document.getElementById('offer-modal').showModal()"
            class="hidden sm:inline-flex items-center px-5 py-2.5 text-sm font-semibold rounded-2xl border border-slate-300 hover:bg-slate-50 transition-all active:scale-[0.985]"
          >
            Make an Offer
          </button>
          <button
            onclick="document.getElementById('offer-modal').showModal()"
            class="inline-flex items-center gap-x-2 px-6 py-2.5 text-sm font-semibold bg-slate-900 hover:bg-black text-white rounded-2xl transition-all active:scale-[0.985] shadow-sm"
          >
            <span>Inquire Now</span>
          </button>
          <button
            id="mobile-menu-btn"
            class="md:hidden w-10 h-10 flex items-center justify-center text-slate-600 hover:text-slate-900"
          >
            <i class="fa-solid fa-bars text-xl"></i>
          </button>
        </div>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <header class="bg-gradient-to-br from-slate-900 via-slate-950 to-slate-800 text-white">
    <div class="max-w-screen-2xl mx-auto px-8 pt-16 pb-20 md:pt-20 md:pb-24">
      <div class="max-w-4xl">
        <div class="inline-flex items-center gap-x-2 px-4 py-1.5 rounded-3xl bg-white/10 backdrop-blur-md border border-white/20 mb-8">
          <div class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></div>
          <span class="text-xs font-semibold tracking-widest uppercase">Premium Domain &bull; Available Now</span>
        </div>

        <h1 class="text-6xl md:text-7xl font-display tracking-tighter leading-none mb-6">
          602Casa<span class="text-accent-400">.</span>com
        </h1>

        <p class="max-w-2xl text-2xl md:text-3xl font-light text-white/90 tracking-tight mb-10 leading-tight">
          The most powerful, memorable domain for <span class="font-medium text-white">homes in the 602</span>.
        </p>

        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
          <button
            onclick="document.getElementById('offer-modal').showModal()"
            class="inline-flex items-center justify-center gap-x-3 px-9 py-4 text-lg font-semibold bg-accent-600 hover:bg-accent-500 active:bg-accent-700 text-white rounded-3xl transition-all shadow-xl shadow-accent-900/30"
