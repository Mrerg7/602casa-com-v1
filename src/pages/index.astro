            <div class="grid grid-cols-2 gap-2 text-sm">
              <div class="flex items-center gap-x-2 text-slate-700"><i class="fa-solid fa-check text-emerald-500 w-4"></i> Real Estate Agents &amp; Teams</div>
              <div class="flex items-center gap-x-2 text-slate-700"><i class="fa-solid fa-check text-emerald-500 w-4"></i> Home Builders &amp; Developers</div>
              <div class="flex items-center gap-x-2 text-slate-700"><i class="fa-solid fa-check text-emerald-500 w-4"></i> Property Management</div>
              <div class="flex items-center gap-x-2 text-slate-700"><i class="fa-solid fa-check text-emerald-500 w-4"></i> Home Services &amp; Remodeling</div>
              <div class="flex items-center gap-x-2 text-slate-700"><i class="fa-solid fa-check text-emerald-500 w-4"></i> Interior Design &amp; Staging</div>
              <div class="flex items-center gap-x-2 text-slate-700"><i class="fa-solid fa-check text-emerald-500 w-4"></i> Mortgage &amp; Title Services</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Market Context -->
  <section class="max-w-screen-2xl mx-auto px-8 py-16">
    <div class="max-w-5xl mx-auto">
      <div class="grid md:grid-cols-12 gap-x-12 items-center">
