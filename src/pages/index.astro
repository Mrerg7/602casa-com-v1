        </div>
        <div class="flex items-center gap-x-2">
          <i class="fa-solid fa-chart-line text-emerald-500"></i>
          <span>High-intent &ldquo;casa&rdquo; + local search value</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Why This Domain -->
  <section id="why" class="max-w-screen-2xl mx-auto px-8 pt-16 pb-12">
    <div class="max-w-3xl mx-auto text-center mb-12">
      <div class="inline-block px-4 py-1 rounded-2xl bg-accent-100 text-accent-700 text-xs font-bold tracking-[1.5px] mb-4">WHY BUYERS CHOOSE 602CASA.COM</div>
