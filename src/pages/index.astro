            class="inline-flex items-center gap-x-3 px-7 py-3.5 bg-slate-900 hover:bg-black text-white font-semibold rounded-2xl text-sm transition-all active:scale-[0.985] shadow-sm"
          >
            <i class="fa-solid fa-envelope"></i>
            <span>sales@desertrich.com</span>
          </a>
          <p class="mt-3 text-xs text-slate-400">Response within 24 hours &bull; Confidential inquiries</p>
        </div>

        <!-- Seller Info & Legal -->
        <div class="flex flex-col justify-between">
          <div>
            <div class="flex items-center gap-x-3 mb-3">
              <div class="w-9 h-9 bg-slate-900 rounded-xl flex items-center justify-center">
                <span class="text-white font-display text-lg font-semibold tracking-tighter">602</span>
              </div>
              <div>
                <span class="font-display text-lg font-semibold tracking-tight">Casa</span>
                <span class="text-[10px] font-mono text-slate-400 tracking-[3px] block -mt-0.5">.COM</span>
              </div>
            </div>
            <p class="text-slate-500 text-sm leading-relaxed mt-4">
              Offered by <span class="font-medium text-slate-700">DesertRich LLC</span>. All serious offers considered.
              Escrow.com or equivalent third-party escrow service recommended for all transactions.
            </p>
          </div>

          <div class="mt-8 pt-6 border-t border-slate-100">
            <p class="text-[11px] text-slate-400 leading-relaxed">
              This website is for demonstration and informational purposes only. It does not constitute an offer of services,
              a commitment to deploy, or a guarantee of outcomes. All statistics, projections, and references to specific
              technologies are based on publicly available information as of the date shown and are subject to change.
            </p>
            <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 text-[11px] text-slate-400">
              <span>&copy; 602Casa.com &mdash; Premium domain asset.</span>
              <span class="hidden sm:inline">&bull;</span>
              <span>Registered with Cloudflare</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </footer>

  <!-- Offer Modal -->
  <dialog
    id="offer-modal"
    class="backdrop:bg-black/60 backdrop:backdrop-blur-sm rounded-3xl p-0 w-full max-w-lg mx-auto shadow-2xl open:flex"
  >
    <div class="bg-white rounded-3xl overflow-hidden w-full">
      <div class="px-8 pt-8 pb-5 border-b flex items-center justify-between">
        <div>
          <div class="font-display text-2xl tracking-tighter">Make an Offer</div>
          <div class="text-xs text-slate-500 mt-0.5">602Casa.com &bull; Confidential inquiry</div>
        </div>
        <button
          onclick="document.getElementById('offer-modal').close()"
          class="text-slate-400 hover:text-slate-600 w-9 h-9 flex items-center justify-center text-3xl leading-none"
        >
          &times;
        </button>
      </div>

      <form id="offer-form" class="p-8 space-y-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label class="block text-xs font-semibold tracking-wider text-slate-600 mb-1.5">FULL NAME</label>
            <input
              type="text"
              id="full-name"
              required
              class="w-full border border-slate-300 focus:border-slate-900 rounded-2xl px-5 py-3 text-sm outline-none transition-colors"
              placeholder="Alex Rivera"
            />
          </div>
          <div>
            <label class="block text-xs font-semibold tracking-wider text-slate-600 mb-1.5">EMAIL ADDRESS</label>
            <input
              type="email"
              id="email"
              required
              class="w-full border border-slate-300 focus:border-slate-900 rounded-2xl px-5 py-3 text-sm outline-none transition-colors"
              placeholder="you@company.com"
            />
          </div>
        </div>

        <div>
          <label class="block text-xs font-semibold tracking-wider text-slate-600 mb-1.5">PHONE (OPTIONAL)</label>
          <input
            type="tel"
            id="phone"
            class="w-full border border-slate-300 focus:border-slate-900 rounded-2xl px-5 py-3 text-sm outline-none transition-colors"
            placeholder="(602) 555-0199"
          />
        </div>

        <div>
          <label class="block text-xs font-semibold tracking-wider text-slate-600 mb-1.5">INTENDED USE / VISION</label>
          <select
            id="intended-use"
            required
            class="w-full border border-slate-300 focus:border-slate-900 rounded-2xl px-5 py-3 text-sm outline-none transition-colors bg-white"
          >
            <option value="">Select an option...</option>
            <option value="Build the 602 Casa home platform (real estate hub, guides, services)">
              Build the 602 Casa home platform
            </option>
            <option value="Brand my real estate, home services, or property business">
              Brand my real estate, home services, or property business
            </option>
            <option value="Real estate team, brokerage, or agent branding">
              Real estate team, brokerage, or agent branding
            </option>
            <option value="Investment / domain portfolio">Investment / domain portfolio</option>
            <option value="Other (please describe below)">Other (please describe below)</option>
          </select>
        </div>

        <div>
          <label class="block text-xs font-semibold tracking-wider text-slate-600 mb-1.5">YOUR OFFER (USD)</label>
          <div class="relative">
            <div class="absolute left-5 top-3.5 text-lg text-slate-400">$</div>
            <input
              type="text"
              id="offer-amount"
              required
              placeholder="12500"
              class="w-full border border-slate-300 focus:border-slate-900 rounded-2xl pl-9 pr-5 py-3 text-sm font-mono outline-none transition-colors"
            />
          </div>
          <div class="text-[10px] text-slate-500 mt-1.5 px-1">All serious offers will be carefully considered.</div>
        </div>

        <div>
          <label class="block text-xs font-semibold tracking-wider text-slate-600 mb-1.5">MESSAGE OR DETAILS</label>
          <textarea
            id="message"
            rows="3"
            class="w-full border border-slate-300 focus:border-slate-900 rounded-3xl px-5 py-3 text-sm outline-none transition-colors resize-y"
            placeholder="Briefly tell us about your plans for 602Casa.com..."
          ></textarea>
        </div>

        <div class="pt-3">
          <button
            type="submit"
            class="w-full flex items-center justify-center gap-x-2 bg-slate-900 hover:bg-black active:bg-slate-950 transition-colors text-white font-semibold py-4 rounded-2xl text-sm tracking-wider"
          >
            <span>SUBMIT CONFIDENTIAL OFFER</span>
          </button>
          <div class="text-center mt-4">
            <div class="text-xs text-slate-500">
              Or email directly:
              <a href="mailto:sales@desertrich.com" class="font-medium text-slate-700 hover:underline">sales@desertrich.com</a>
            </div>
          </div>
        </div>
      </form>
    </div>
  </dialog>

  <!-- Success Modal -->
  <dialog
    id="success-modal"
    class="backdrop:bg-black/60 backdrop:backdrop-blur-sm rounded-3xl p-0 w-full max-w-md mx-auto"
  >
    <div class="bg-white rounded-3xl p-9 text-center">
      <div class="mx-auto w-16 h-16 bg-emerald-100 rounded-full flex items-center justify-center mb-6">
        <i class="fa-solid fa-check text-emerald-600 text-4xl"></i>
      </div>
      <h3 class="font-display text-3xl tracking-tight">Thank you. Your inquiry was received.</h3>
      <p class="mt-3 text-slate-600">The owner will personally review your offer and respond within 24&ndash;48 hours.</p>
      <div class="mt-8 flex flex-col gap-y-3">
        <button
          onclick="document.getElementById('success-modal').close(); document.getElementById('offer-modal').close();"
          class="w-full py-3.5 text-sm font-semibold border border-slate-300 hover:bg-slate-50 rounded-2xl transition-colors"
        >
          Close Window
        </button>
        <a href="mailto:sales@desertrich.com" class="text-xs text-slate-500 hover:text-slate-700"
          >Need immediate assistance? Email sales@desertrich.com</a
        >
      </div>
    </div>
  </dialog>

  <!-- Site Scripts -->
  <script>
    // @ts-nocheck
    (function () {
      // Navbar scroll effect
      const navbar = document.getElementById('navbar');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 80) {
          navbar.classList.add('shadow-sm', 'bg-white/95', 'backdrop-blur-md');
        } else {
          navbar.classList.remove('shadow-sm', 'bg-white/95', 'backdrop-blur-md');
        }
      });

      // Mobile menu
      document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
        const overlay = document.createElement('div');
        overlay.className = 'fixed inset-0 bg-black/60 z-[100] md:hidden';
        overlay.innerHTML = `
          <div class="bg-white w-72 h-full p-8 shadow-2xl">
            <div class="flex justify-between items-center mb-10">
              <div class="flex items-center gap-x-2.5">
                <div class="w-9 h-9 bg-slate-900 rounded-2xl flex items-center justify-center">
                  <span class="text-white font-display text-xl font-semibold tracking-tighter">602</span>
                </div>
                <span class="font-display text-2xl font-semibold tracking-tighter">Casa</span>
              </div>
              <button class="close-btn text-3xl text-slate-400 hover:text-slate-600">&times;</button>
            </div>
            <div class="flex flex-col gap-y-1 text-lg font-medium">
              <a href="#why" class="nav-link py-3 px-1 text-slate-700 hover:text-slate-900 border-b border-slate-100">Why This Domain</a>
              <a href="#opportunity" class="nav-link py-3 px-1 text-slate-700 hover:text-slate-900 border-b border-slate-100">The Opportunity</a>
              <a href="#value" class="nav-link py-3 px-1 text-slate-700 hover:text-slate-900 border-b border-slate-100">Market Value</a>
              <a href="#acquire" class="nav-link py-3 px-1 text-slate-700 hover:text-slate-900 border-b border-slate-100">How to Acquire</a>
            </div>
            <div class="mt-auto pt-8">
              <button class="inquiry-btn w-full py-4 bg-slate-900 text-white font-semibold rounded-2xl text-sm">Make an Offer</button>
            </div>
          </div>
        `;
        document.body.appendChild(overlay);

        const remove = () => overlay.remove();
        overlay.querySelector('.close-btn').onclick = remove;
        overlay.onclick = (e) => { if (e.target === overlay) remove(); };
        overlay.querySelector('.inquiry-btn').onclick = () => {
          remove();
          document.getElementById('offer-modal')?.showModal();
        };
        overlay.querySelectorAll('.nav-link').forEach((link) => {
          link.onclick = () => {
            const href = link.getAttribute('href');
            remove();
            setTimeout(() => {
              const target = document.querySelector(href);
              if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }, 80);
          };
        });
      });

      // Offer form
      const form = document.getElementById('offer-form');
      if (form) {
        form.addEventListener('submit', function (e) {
          e.preventDefault();
          const btn = this.querySelector('button[type="submit"]');
          const orig = btn.innerHTML;
          btn.disabled = true;
          btn.innerHTML = `<span class="flex items-center justify-center gap-x-2">
            <svg class="animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <span>Submitting...</span></span>`;
          setTimeout(() => {
            document.getElementById('offer-modal')?.close();
            this.reset();
            btn.disabled = false;
            btn.innerHTML = orig;
            document.getElementById('success-modal')?.showModal();
          }, 1250);
        });
      }

      // Logo click to top
      const logo = document.querySelector('.flex.items-center.gap-x-2\\.5');
      if (logo) {
        logo.style.cursor = 'pointer';
        logo.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
      }
    })();
  </script>
</BaseLayout>
